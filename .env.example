# Antigravity — Environment Variables
# Copy this to .env and fill in your values

# Application
APP_NAME=Antigravity
DEBUG=true

# Database (Supabase or local PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/antigravity

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# Ollama (LLM — requires GPU machine)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Simulation defaults
MONTE_CARLO_DEFAULT_RUNS=10000
SIMULATION_TIME_HORIZON_YEARS=10
